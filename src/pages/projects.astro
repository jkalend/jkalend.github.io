---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle";
import { ProjectCard } from "../components/ProjectCard";
import { projects } from "../lib/projects";
import { FolderGit2, ArrowLeft } from "lucide-react";

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Projects | Andrea Kalenda">
  <ThemeToggle client:load />
  <div class="relative min-h-screen bg-background">
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-transparent to-muted/30 transition-opacity duration-200 ease-in-out" />
    <div class="relative mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8 space-y-10">
      <header class="space-y-4">
        <a
          href={baseUrl}
          class="inline-flex items-center gap-2 text-sm text-muted-foreground transition-colors hover:text-blue-600 dark:hover:text-blue-400"
        >
          <ArrowLeft class="h-4 w-4" />
          Back to resume
        </a>
        <div class="flex items-center gap-2">
          <FolderGit2 class="h-6 w-6 text-primary" />
          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">Projects</h1>
        </div>
        <p class="max-w-3xl text-muted-foreground">
          A more detailed look at projects spanning software engineering, machine learning, and systems design, with enough context to show the technical scope and outcomes behind each one.
        </p>
      </header>

      <div class="flex flex-col gap-5">
        {projects.map((proj, i) => (
          <ProjectCard key={i} project={proj} variant="detailed" client:load />
        ))}
      </div>

      <footer class="text-center text-xs text-muted-foreground pt-6 pb-2">
        Built with Astro, React &amp; shadcn/ui
      </footer>
    </div>
  </div>
</Layout>
